/* =========================================================
   XUYNH — Frozen Yoghurt
   Palette + type derived from the brand mark:
   terracotta #B75035 + cream #F2EEE3, warm honey & blush
   accents pulled from the froyo product photography.
   ========================================================= */

:root {
  --cream:      #F2EEE3;
  --cream-soft: #F8F5EC;
  --brick:      #B75035;
  --brick-deep: #8C3A22;
  --brick-ink:  #5E2213;
  --honey:      #E6A23C;
  --honey-deep: #CF8524;
  --blush:      #EFC9BB;
  --blush-deep: #E0A491;
  --cocoa:      #3E2118;
  --ink:        #37231B;

  --wrap: 1240px;
  --gutter: clamp(1.15rem, 4vw, 3.25rem);

  --font-display: "Fraunces", "Times New Roman", serif;
  --font-body: "Hanken Grotesk", system-ui, -apple-system, sans-serif;

  --ease: cubic-bezier(.22,.61,.36,1);
}

/* ---------- reset-ish ---------- */
*, *::before, *::after { box-sizing: border-box; }
html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
body {
  margin: 0;
  background: var(--cream);
  color: var(--ink);
  font-family: var(--font-body);
  font-size: clamp(1rem, 0.6vw + 0.9rem, 1.125rem);
  line-height: 1.62;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { font: inherit; cursor: pointer; }

.wrap { width: min(100% - var(--gutter)*2, var(--wrap)); margin-inline: auto; }

/* focus */
a:focus-visible, button:focus-visible {
  outline: 3px solid var(--cocoa);
  outline-offset: 3px;
  border-radius: 4px;
}

/* ---------- typography helpers ---------- */
.eyebrow {
  font-family: var(--font-body);
  font-weight: 800;
  font-size: .78rem;
  letter-spacing: .2em;
  text-transform: uppercase;
}
.display {
  font-family: var(--font-display);
  font-optical-sizing: auto;
  font-weight: 900;
  font-variation-settings: "SOFT" 40, "WONK" 0;
  line-height: 0.9;
  letter-spacing: -0.015em;
  text-wrap: balance;
}

/* Signature move: chunky hard offset shadow on big serif type */
.offset-cream {
  color: var(--cream);
  text-shadow: 0.045em 0.05em 0 var(--brick-deep);
}
.offset-brick {
  color: var(--brick);
  text-shadow: 0.045em 0.05em 0 var(--honey);
}
.offset-honey {
  color: var(--honey);
  text-shadow: 0.045em 0.05em 0 var(--brick-deep);
}

/* ---------- buttons ---------- */
.btn {
  display: inline-flex; align-items: center; gap: .55rem;
  font-weight: 800; font-size: .95rem; letter-spacing: .02em;
  padding: .95rem 1.6rem;
  border-radius: 999px;
  border: 2px solid var(--brick-ink);
  transition: transform .18s var(--ease), background .18s var(--ease), color .18s var(--ease);
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }
.btn--solid { background: var(--brick); color: var(--cream); }
.btn--solid:hover { background: var(--brick-deep); }
.btn--cream { background: var(--cream); color: var(--brick-ink); }
.btn--cream:hover { background: #fff; }
.btn--honey { background: var(--honey); color: var(--brick-ink); border-color: var(--brick-ink); }
.btn--honey:hover { background: var(--honey-deep); }
.btn--ghost { background: transparent; }

.swirl-ico { width: 1.15em; height: 1.15em; flex: none; }

/* =========================================================
   NAV
   ========================================================= */
.nav {
  position: sticky; top: 0; z-index: 60;
  background: var(--brick);
  color: var(--cream);
  border-bottom: 2px solid var(--brick-deep);
}
.nav__inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: 68px;
}
.nav__links { display: flex; gap: 1.5rem; align-items: center; }
.nav__links--right { justify-self: end; }
.nav a.nav__link {
  font-weight: 800; font-size: .82rem; letter-spacing: .12em;
  text-transform: uppercase; opacity: .92;
  display: inline-flex; align-items: center; gap: .4rem;
}
.nav a.nav__link:hover { opacity: 1; }
.brand {
  justify-self: center;
  display: inline-flex; align-items: center; gap: .5rem;
  font-family: var(--font-display); font-weight: 900;
  font-variation-settings: "SOFT" 40;
  font-size: 1.55rem; letter-spacing: .01em; color: var(--cream);
}
.brand .swirl-ico { width: 1.15em; height: 1.35em; }
.nav__burger { display: none; }

/* =========================================================
   HERO
   ========================================================= */
.hero {
  position: relative;
  background: var(--brick);
  color: var(--cream);
  overflow: hidden;
  padding-block: clamp(2.5rem, 6vw, 4.5rem) 0;
}
.hero__eyebrow {
  color: var(--cream); opacity: .9;
  display: inline-flex; align-items: center; gap: .6rem;
  margin-bottom: clamp(1rem, 2.5vw, 1.6rem);
}
.hero__title {
  font-size: clamp(2.4rem, 8.5vw, 8rem);
  margin: 0;
}
.hero__title .line2 { display: block; }
.hero__grid { position: relative; z-index: 2; }
.hero__row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: clamp(1rem, 4vw, 3rem);
  align-items: end;
  margin-top: clamp(1.2rem, 3vw, 2.2rem);
}
.hero__copy { padding-bottom: clamp(2rem, 5vw, 4rem); }
.hero__lead {
  max-width: 34ch;
  font-size: clamp(1.05rem, 1.4vw, 1.3rem);
  line-height: 1.5;
  margin: 0 0 1.8rem;
  color: #F7EFE6;
}
.hero__cta { display: flex; flex-wrap: wrap; gap: .8rem; }

/* product image breaking the bottom edge */
.hero__photo {
  position: relative;
  justify-self: end;
  align-self: end;
  width: min(42vw, 400px);
  margin-bottom: -2px;
  filter: drop-shadow(0 22px 30px rgba(52,16,6,.35));
}
.hero__photo img { border-radius: 14px 14px 0 0; }

/* rotating starburst badge */
.starburst {
  position: absolute;
  display: grid; place-items: center;
  text-align: center;
  color: var(--brick-ink);
  font-weight: 800; text-transform: uppercase; letter-spacing: .06em;
  line-height: 1.05;
}
.starburst svg { position: absolute; inset: 0; width: 100%; height: 100%; color: var(--honey); }
.starburst--spin svg { animation: spin 22s linear infinite; }
.starburst span { position: relative; z-index: 2; }
.hero__badge {
  width: clamp(112px, 14vw, 168px); aspect-ratio: 1;
  top: 8%; right: 3%;
  font-size: clamp(.72rem, 1.1vw, .95rem);
}

@keyframes spin { to { transform: rotate(360deg); } }

/* hero doodles */
.doodle { position: absolute; z-index: 1; opacity: .9; pointer-events: none; }
.doodle--zig1 { left: 2%; top: 30%; width: 90px; color: var(--honey); }
.doodle--zig2 { right: 40%; bottom: 12%; width: 70px; color: var(--blush); }
.doodle--star { left: 46%; top: 6%; width: 42px; color: var(--honey); }

/* =========================================================
   MARQUEE
   ========================================================= */
.marquee {
  background: var(--honey);
  color: var(--brick-ink);
  border-block: 2px solid var(--brick-ink);
  overflow: hidden;
  padding-block: .7rem;
}
.marquee__track {
  display: flex; width: max-content;
  animation: scroll-x 34s linear infinite;
}
.marquee__track span {
  font-family: var(--font-display); font-weight: 900;
  font-variation-settings: "SOFT" 60;
  font-size: 1.35rem; letter-spacing: .02em;
  text-transform: uppercase;
  padding-inline: 1.1rem;
  display: inline-flex; align-items: center; gap: 1rem;
  white-space: nowrap;
}
.marquee .swirl-ico { width: 1.2em; height: 1.4em; }
@keyframes scroll-x { to { transform: translateX(-50%); } }
.marquee--blush { background: var(--blush); }

/* =========================================================
   STORY
   ========================================================= */
.story {
  position: relative;
  background: var(--blush);
  color: var(--brick-ink);
  padding-block: clamp(3.5rem, 9vw, 7rem);
  overflow: hidden;
}
.story__grid {
  position: relative; z-index: 2;
  display: grid; grid-template-columns: 1.15fr .85fr;
  gap: clamp(1.5rem, 5vw, 4rem); align-items: center;
}
.story__title { font-size: clamp(2.6rem, 7vw, 5.6rem); margin: 0 0 1.4rem; }
.story__body p { max-width: 46ch; margin: 0 0 1.1rem; color: #6a2d1c; }
.story__facts { list-style: none; margin: 1.6rem 0 0; padding: 0; display: grid; gap: .85rem; }
.story__facts li {
  display: flex; gap: .8rem; align-items: flex-start;
  font-weight: 500;
}
.story__facts .swirl-ico { color: var(--brick); width: 1.5rem; height: 1.7rem; margin-top: .1rem; }
.story__facts b { font-weight: 800; }

/* blobs */
.blob { position: absolute; z-index: 1; background: var(--cream); opacity: .55; }
.blob--1 { width: 340px; height: 300px; top: -60px; right: -40px;
  border-radius: 60% 40% 55% 45% / 55% 50% 50% 45%; }
.blob--2 { width: 280px; height: 260px; bottom: -70px; left: -60px;
  border-radius: 50% 50% 45% 55% / 45% 55% 45% 55%; }

/* =========================================================
   FLAVOURS
   ========================================================= */
.flavours {
  background: var(--cream);
  padding-block: clamp(3.5rem, 9vw, 6.5rem);
}
.section-head { margin-bottom: clamp(2rem, 5vw, 3.2rem); }
.section-head .eyebrow { color: var(--brick); }
.section-head h2 { font-size: clamp(2.4rem, 6vw, 4.6rem); margin: .5rem 0 0; }

.flav-grid {
  display: grid; gap: 1.1rem;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
}
.flav-card {
  background: var(--cream-soft);
  border: 2px solid var(--brick-ink);
  border-radius: 20px;
  padding: 1.5rem 1.4rem 1.6rem;
  transition: transform .2s var(--ease), background .2s var(--ease);
}
.flav-card:hover { transform: translateY(-6px) rotate(-1deg); background: #fff; }
.flav-card .swirl-ico { width: 2.6rem; height: 3.1rem; color: var(--brick); }
.flav-card h3 { font-family: var(--font-display); font-weight: 900; font-size: 1.55rem; margin: .9rem 0 .35rem; color: var(--brick-ink); }
.flav-card p { margin: 0; font-size: .96rem; color: #6a4438; }
.flav-card .tag { display:inline-block; margin-top: .9rem; font-size:.72rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; color: var(--brick); }
.flav-card--feature { background: var(--brick); color: var(--cream); }
.flav-card--feature h3, .flav-card--feature .swirl-ico { color: var(--cream); }
.flav-card--feature p { color: #f4e6df; }
.flav-card--feature .tag { color: var(--honey); }

/* =========================================================
   SIGNATURE SWIRLS (photo showcase)
   ========================================================= */
.signature {
  background: var(--cocoa);
  color: var(--cream);
  padding-block: clamp(3.5rem, 9vw, 6.5rem);
  position: relative;
}
.signature .section-head .eyebrow { color: var(--honey); }
.signature .section-head h2 { color: var(--cream); }
.sig-grid {
  display: grid; gap: 1.4rem;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}
.sig-card {
  background: #4c2a20;
  border: 2px solid #1f0f0a;
  border-radius: 22px;
  overflow: hidden;
  transition: transform .2s var(--ease);
}
.sig-card:hover { transform: translateY(-6px); }
.sig-card__img { position: relative; aspect-ratio: 4/5; overflow: hidden; }
.sig-card__img img { width: 100%; height: 100%; object-fit: cover; }
.sig-card__num {
  position: absolute; top: .7rem; left: .9rem;
  font-family: var(--font-display); font-weight: 900; font-size: 1.4rem;
  color: var(--cream); text-shadow: 0 2px 8px rgba(0,0,0,.5);
}
.sig-card__body { padding: 1.2rem 1.3rem 1.5rem; }
.sig-card__body h3 { font-family: var(--font-display); font-weight: 900; font-size: 1.65rem; margin: 0 0 .4rem; color: var(--cream); }
.sig-card__body p { margin: 0; font-size: .95rem; color: #e6cfc4; }

/* =========================================================
   ORDER / LOCATIONS
   ========================================================= */
.order {
  background: var(--brick);
  color: var(--cream);
  padding-block: clamp(3.5rem, 9vw, 7rem);
  position: relative; overflow: hidden;
}
.order__inner { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: center; }
.order h2 { font-size: clamp(2.6rem, 7vw, 6rem); margin: .4rem 0 1.2rem; }
.order p { max-width: 40ch; color: #f6e9e1; margin: 0 0 1.7rem; }
.order__cta { display: flex; flex-wrap: wrap; gap: .8rem; }
.order__badge { position: relative; width: clamp(150px, 20vw, 230px); aspect-ratio: 1; color: var(--brick-ink); font-size: clamp(.85rem,1.4vw,1.15rem); }
.order .doodle--zig1 { top: 12%; left: 46%; color: var(--honey); }

/* =========================================================
   FOOTER
   ========================================================= */
.footer {
  background: var(--cocoa);
  color: var(--cream);
  padding-block: clamp(2.8rem, 6vw, 4.5rem) 2rem;
}
.footer__top { display: grid; grid-template-columns: 1.3fr 1fr 1fr; gap: 2rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(242,238,227,.2); }
.footer .brand { justify-self: start; font-size: 2rem; margin-bottom: .8rem; }
.footer__tag { max-width: 32ch; color: #d9c3b8; }
.footer h4 { font-size: .78rem; letter-spacing: .18em; text-transform: uppercase; margin: 0 0 1rem; color: var(--honey); font-weight: 800; }
.footer ul { list-style: none; margin: 0; padding: 0; display: grid; gap: .55rem; }
.footer ul a:hover { color: var(--honey); }
.footer__hours span { display: block; color: #d9c3b8; font-size: .95rem; }
.footer__bottom { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-top: 1.6rem; font-size: .85rem; color: #bfa89d; }

/* =========================================================
   SCROLL REVEAL
   ========================================================= */
.reveal { opacity: 1; transform: none; transition: opacity .7s var(--ease), transform .7s var(--ease); }
.js-anim .reveal { opacity: 0; transform: translateY(26px); }
.js-anim .reveal.in { opacity: 1; transform: none; }
.reveal.in { opacity: 1; transform: none; }

/* =========================================================
   RESPONSIVE
   ========================================================= */
@media (max-width: 760px) {
  .hero__row { grid-template-columns: 1fr; }
  .hero__photo { width: min(72%, 320px); justify-self: center; margin-top: .5rem; }
  .hero__badge { top: 4%; right: -2%; }
}
@media (max-width: 900px) {
  .story__grid { grid-template-columns: 1fr; }
  .order__inner { grid-template-columns: 1fr; }
  .order__badge { justify-self: start; }
  .footer__top { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 680px) {
  .nav__inner { grid-template-columns: auto 1fr; }
  .nav__links--left { display: none; }
  .nav__links--right { display: none; }
  .brand { justify-self: start; }
  .nav__burger {
    display: inline-flex; justify-self: end;
    background: transparent; border: 2px solid var(--cream);
    color: var(--cream); border-radius: 999px; padding: .5rem .95rem;
    font-weight: 800; font-size: .78rem; letter-spacing: .1em; text-transform: uppercase;
  }
  .mobile-menu { display: none; }
  .mobile-menu.open { display: block; }
  .mobile-menu {
    background: var(--brick-deep); border-bottom: 2px solid var(--brick-ink);
    padding: 1rem var(--gutter) 1.4rem;
  }
  .mobile-menu a { display: block; padding: .7rem 0; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; font-size: .95rem; color: var(--cream); border-bottom: 1px solid rgba(242,238,227,.15); }
  .hero__title { font-size: clamp(2.2rem, 8.5vw, 4.6rem); }
  .footer__top { grid-template-columns: 1fr; }
  .flav-card:hover { transform: translateY(-4px); }
}
.mobile-menu { display: none; }

/* reduced motion */
@media (prefers-reduced-motion: reduce) {
  * { scroll-behavior: auto !important; }
  .marquee__track { animation: none; }
  .starburst--spin svg { animation: none; }
  .reveal { opacity: 1; transform: none; transition: none; }
  .btn:hover, .flav-card:hover, .sig-card:hover { transform: none; }
}
